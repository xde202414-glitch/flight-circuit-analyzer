# ===========================================
# 飞行营地飞行程序分析工具 — API 密钥配置
# 复制此文件为 .env 并填入你的密钥
# ===========================================

# 高德地图 Web服务 API Key（可选，用于建筑搜索备用）
# 申请地址: https://console.amap.com/dev/key/app
AMAP_KEY=your_amap_key_here

# 星图地球数据云 Token（用于3D地形高程数据）
# 申请地址: https://www.geovisearth.com/
GEOVIS_TOKEN=your_geovis_token_here

# 天地图 服务端 Key（用于POI搜索和卫星影像）
# 申请地址: https://console.tianditu.gov.cn/api注册
TIANDITU_KEY=your_tianditu_key_here
